{
  "name": "repo-doctor-ai",
  "version": "0.1.0",
  "description": "A TypeScript CLI health scanner for making repositories clearer, safer, and more trustworthy.",
  "type": "module",
  "homepage": "https://github.com/hadnan1994/Repo-Doctor-AI#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hadnan1994/Repo-Doctor-AI.git"
  },
  "bugs": {
    "url": "https://github.com/hadnan1994/Repo-Doctor-AI/issues"
  },
  "bin": {
    "repo-doctor-ai": "./dist/cli.js"
  },
  "files": [
    "dist",
    "examples",
    "CHANGELOG.md",
    "SECURITY.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "repository",
    "health",
    "scanner",
    "typescript",
    "github",
    "open-source",
    "repo-health",
    "developer-tools",
    "ci"
  ],
  "author": "Repo Doctor AI contributors",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "picocolors": "^1.1.1",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}